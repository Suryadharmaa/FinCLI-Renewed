# FinCLI v0.1 environment example
# Copy to .env and fill only the providers you use.

# AI providers
OPENROUTER_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TOGETHER_API_KEY=
HUGGINGFACE_API_KEY=
GROQ_API_KEY=

# Market/news providers
MARKET_DATA_API_KEY=
NEWS_DATA_API_KEY=
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=

# Optional custom market provider.
# Select "Custom API" from /news_model in the TUI.
# Expected endpoints:
# - GET {MARKET_DATA_BASE_URL}/quote/{symbol}
# - GET {MARKET_DATA_BASE_URL}/history/{symbol}?period=6mo&interval=1d
# - GET {MARKET_DATA_BASE_URL}/news/{symbol}?limit=5
# - GET {MARKET_DATA_BASE_URL}/fundamentals/{symbol}
MARKET_DATA_BASE_URL=

# Optional runtime defaults
FINCLI_TIMEZONE=Asia/Jakarta
FINCLI_DEFAULT_CURRENCY=USD
